generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
  VIEWER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String
  role           Role            @default(VIEWER)
  createdAt      DateTime        @default(now())
  timeEntries    TimeEntry[]
  reimbursements Reimbursement[]
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  startTime   String
  endTime     String
  durationMin Float
  description String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model Reimbursement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  amount      Float
  description String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model MonthlySettings {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  payRate   Float    @default(20)
  isPaid    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}
